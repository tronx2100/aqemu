<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <author>Andrey Rijov</author>
 <class>SMP_Settings_Window</class>
 <widget class="QDialog" name="SMP_Settings_Window">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>560</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>CPU Settings</string>
  </property>
  <property name="windowIcon">
   <iconset resource="../resources/icons.qrc">
    <normaloff>:/exec.png</normaloff>:/exec.png</iconset>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QLabel" name="Label_Info_Text">
     <property name="text">
      <string>All of these values can be omitted.
Missing values (zeroes) get computed automatically.</string>
     </property>
    </widget>
   </item>
   <item>
    <widget class="Line" name="line_1">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout_Topology">
     <item>
      <layout class="QGridLayout" name="gridLayout_2">
       <item row="0" column="0">
        <widget class="QLabel" name="Label_CPUs">
         <property name="text">
          <string>CP&amp;U count:</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set>
         </property>
         <property name="buddy">
          <cstring>SB_SMP</cstring>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QSpinBox" name="SB_SMP">
         <property name="minimum">
          <number>1</number>
         </property>
         <property name="maximum">
          <number>255</number>
         </property>
         <property name="value">
          <number>1</number>
         </property>
        </widget>
       </item>
       <item row="1" column="0">
        <widget class="QLabel" name="Label_Sockets">
         <property name="text">
          <string>Soc&amp;ket count:</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set>
         </property>
         <property name="buddy">
          <cstring>SB_Sockets</cstring>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QSpinBox" name="SB_Sockets">
         <property name="maximum">
          <number>255</number>
         </property>
         <property name="value">
          <number>0</number>
         </property>
        </widget>
       </item>
      </layout>
     </item>
     <item>
      <layout class="QGridLayout" name="gridLayout">
       <item row="0" column="0">
        <widget class="QLabel" name="Label_Cores">
         <property name="text">
          <string>Cores per socket:</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set>
         </property>
         <property name="buddy">
          <cstring>SB_Cores</cstring>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QSpinBox" name="SB_Cores">
         <property name="maximum">
          <number>255</number>
         </property>
         <property name="value">
          <number>0</number>
         </property>
        </widget>
       </item>
       <item row="1" column="0">
        <widget class="QLabel" name="Lebel_Threads">
         <property name="text">
          <string>&amp;Threads per core:</string>
         </property>
         <property name="alignment">
          <set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set>
         </property>
         <property name="buddy">
          <cstring>SB_Threads</cstring>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QSpinBox" name="SB_Threads">
         <property name="maximum">
          <number>255</number>
         </property>
         <property name="value">
          <number>0</number>
         </property>
        </widget>
       </item>
      </layout>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout_MaxCPUs">
     <item>
      <widget class="QLabel" name="Label_MaxCPUs">
       <property name="text">
        <string>Maximum &amp;number of hotpluggable CPUs:</string>
       </property>
       <property name="buddy">
        <cstring>SB_MaxCPUs</cstring>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QSpinBox" name="SB_MaxCPUs">
       <property name="maximum">
        <number>255</number>
       </property>
       <property name="value">
        <number>0</number>
       </property>
      </widget>
     </item>
     <item>
      <spacer name="horizontalSpacer_MaxCPUs">
       <property name="orientation">
        <enum>Qt::Horizontal</enum>
       </property>
       <property name="sizeHint" stdset="0">
        <size>
         <width>40</width>
         <height>20</height>
        </size>
       </property>
       </spacer>
      </item>
      <item>
       <widget class="QPushButton" name="PB_Hyperthreading">
        <property name="text">
         <string>Hyper-Threading &amp;Layout</string>
        </property>
       </widget>
      </item>
      <item>
       <spacer name="horizontalSpacer_HT_After">
        <property name="orientation">
         <enum>Qt::Horizontal</enum>
        </property>
        <property name="sizeHint" stdset="0">
         <size>
          <width>40</width>
          <height>20</height>
         </size>
        </property>
       </spacer>
      </item>
      </layout>
     </item>
     <item>
      <widget class="Line" name="line_3">
       <property name="orientation">
        <enum>Qt::Horizontal</enum>
       </property>
      </widget>
     </item>
   <item>
    <widget class="QGroupBox" name="GB_CPU_Features">
     <property name="title">
      <string>CPU Features (appended to -cpu &amp;lt;model&amp;gt;,...)</string>
     </property>
      <layout class="QVBoxLayout" name="verticalLayout_Features">
       <item>
        <widget class="QLineEdit" name="LE_CPU_Flags">
         <property name="placeholderText">
          <string>kvm=off,-hypervisor,+topoext,hv_relaxed,hv_vapic,hv_time,...</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="Label_Common_Flags">
         <property name="text">
          <string>Common flags (click to add/remove):</string>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QGridLayout" name="gridLayout_Checkboxes">
         <item row="0" column="0">
          <widget class="QCheckBox" name="CB_KVM_Off">
           <property name="text">
            <string>kvm=off</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="QCheckBox" name="CB_Hide_Hypervisor">
           <property name="text">
            <string>-hypervisor</string>
           </property>
          </widget>
         </item>
         <item row="0" column="2">
          <widget class="QCheckBox" name="CB_TopoExt">
           <property name="text">
            <string>+topoext</string>
           </property>
          </widget>
         </item>
         <item row="0" column="3">
          <widget class="QCheckBox" name="CB_HV_Relaxed">
           <property name="text">
            <string>hv_relaxed</string>
           </property>
          </widget>
         </item>
         <item row="1" column="0">
          <widget class="QCheckBox" name="CB_HV_VAPIC">
           <property name="text">
            <string>hv_vapic</string>
           </property>
          </widget>
         </item>
         <item row="1" column="1">
          <widget class="QCheckBox" name="CB_HV_Time">
           <property name="text">
            <string>hv_time</string>
           </property>
          </widget>
         </item>
         <item row="1" column="2">
          <widget class="QCheckBox" name="CB_HV_Stimer">
           <property name="text">
            <string>hv_stimer</string>
           </property>
          </widget>
         </item>
         <item row="1" column="3">
          <widget class="QCheckBox" name="CB_HV_SynIC">
           <property name="text">
            <string>hv_synic</string>
           </property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QCheckBox" name="CB_HV_Reset">
           <property name="text">
            <string>hv_reset</string>
           </property>
          </widget>
         </item>
         <item row="2" column="1">
          <widget class="QCheckBox" name="CB_HV_Frequencies">
           <property name="text">
            <string>hv_frequencies</string>
           </property>
          </widget>
         </item>
         <item row="2" column="2">
          <layout class="QHBoxLayout" name="horizontalLayout_Spinlocks">
           <item>
            <widget class="QCheckBox" name="CB_HV_Spinlocks">
             <property name="text">
              <string>hv_spinlocks=</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLineEdit" name="LE_HV_Spinlocks">
             <property name="text">
              <string>0x1fff</string>
             </property>
             <property name="enabled">
              <bool>false</bool>
             </property>
             <property name="maximumSize">
              <size>
               <width>100</width>
               <height>16777215</height>
              </size>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         <item row="2" column="3">
          <layout class="QHBoxLayout" name="horizontalLayout_VendorID">
           <item>
            <widget class="QCheckBox" name="CB_HV_Vendor_ID">
             <property name="text">
              <string>hv_vendor_id=</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLineEdit" name="LE_HV_Vendor_ID">
             <property name="text">
              <string>AuthenticAMD</string>
             </property>
             <property name="enabled">
              <bool>false</bool>
             </property>
             <property name="maximumSize">
              <size>
               <width>150</width>
               <height>16777215</height>
              </size>
             </property>
            </widget>
           </item>
          </layout>
         </item>
         </layout>
        </item>
        <item>
         <widget class="QCheckBox" name="CH_CPU_PM_Overcommit">
          <property name="text">
           <string>CPU PM overcommit (cpu-pm=on)</string>
          </property>
          <property name="toolTip">
           <string>Enable overcommit for CPU power management (-overcommit cpu-pm=on). Useful for macOS/OSX guests.</string>
          </property>
         </widget>
        </item>
       </layout>
     </widget>
    </item>
    <item>
     <widget class="Line" name="line_2">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout_Buttons">
     <item>
      <widget class="QPushButton" name="PB_Optimized_AMD">
       <property name="text">
        <string>Optimized &amp;AMD</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="PB_Optimized_Intel">
       <property name="text">
        <string>Optimized &amp;Intel</string>
       </property>
      </widget>
     </item>
     <item>
       <widget class="QPushButton" name="PB_OSX_Preset">
        <property name="text">
         <string>OSX &amp;Preset</string>
        </property>
       </widget>
     </item>
     <item>
      <spacer name="horizontalSpacer">
       <property name="orientation">
        <enum>Qt::Horizontal</enum>
       </property>
       <property name="sizeHint" stdset="0">
        <size>
         <width>205</width>
         <height>20</height>
        </size>
       </property>
      </spacer>
     </item>
     <item>
      <widget class="Dialog_Button_Box" name="buttonBox">
       <property name="standardButtons">
        <set>QDialogButtonBox::Cancel|QDialogButtonBox::Ok</set>
       </property>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
 <customwidgets>
  <customwidget>
   <class>Dialog_Button_Box</class>
   <extends>QDialogButtonBox</extends>
   <header>Dialog_Button_Box.h</header>
  </customwidget>
 </customwidgets>
