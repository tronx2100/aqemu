 <resources>
  <include location="../resources/icons.qrc"/>
 </resources>
 <connections>
  <connection>
   <sender>CB_HV_Spinlocks</sender>
   <signal>toggled(bool)</signal>
   <receiver>LE_HV_Spinlocks</receiver>
   <slot>setEnabled(bool)</slot>
   <hints>
    <hint type="sourcelabel">
     <x>50</x>
     <y>50</y>
    </hint>
    <hint type="destinationlabel">
     <x>150</x>
     <y>50</y>
    </hint>
   </hints>
  </connection>
  <connection>
   <sender>CB_HV_Vendor_ID</sender>
   <signal>toggled(bool)</signal>
   <receiver>LE_HV_Vendor_ID</receiver>
   <slot>setEnabled(bool)</slot>
   <hints>
    <hint type="sourcelabel">
     <x>50</x>
     <y>50</y>
    </hint>
    <hint type="destinationlabel">
     <x>150</x>
     <y>50</y>
    </hint>
   </hints>
  </connection>
  <connection>
   <sender>buttonBox</sender>
   <signal>accepted()</signal>
   <receiver>SMP_Settings_Window</receiver>
   <slot>accept()</slot>
   <hints>
    <hint type="sourcelabel">
     <x>324</x>
     <y>228</y>
    </hint>
    <hint type="destinationlabel">
     <x>218</x>
     <y>128</y>
    </hint>
   </hints>
  </connection>
  <connection>
   <sender>buttonBox</sender>
   <signal>rejected()</signal>
   <receiver>SMP_Settings_Window</receiver>
   <slot>reject()</slot>
   <hints>
    <hint type="sourcelabel">
     <x>324</x>
     <y>228</y>
    </hint>
    <hint type="destinationlabel">
     <x>218</x>
